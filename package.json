{
    "name": "foosboard",
    "private": true,
    "version": "1.1.2",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "test": "vitest run --coverage",
        "test:unit": "vitest run",
        "test:unit:headed": "vitest run --config vitest.browser.config.ts",
        "test:watch": "vitest",
        "test:e2e": "playwright test",
        "test:e2e:headed": "PLAYWRIGHT_HEADED=1 playwright test",
        "test:smoke": "playwright test e2e/smoke.spec.ts",
        "test:smoke:headed": "PLAYWRIGHT_HEADED=1 playwright test e2e/smoke.spec.ts",
        "test:all": "npm run test:unit && npm run test:e2e"
    },
    "dependencies": {
        "@mantine/core": "^7.13.2",
        "@mantine/dropzone": "^7.13.2",
        "@mantine/hooks": "^7.13.2",
        "lucide-react": "^0.487.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "zustand": "^5.0.3"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^25.6.0",
        "@types/react": "^19.0.10",
        "@types/react-dom": "^19.0.4",
        "@vitejs/plugin-react": "^4.3.4",
        "@vitest/browser": "^4.1.5",
        "@vitest/browser-playwright": "^4.1.5",
        "@vitest/coverage-v8": "^4.1.4",
        "jsdom": "^29.0.2",
        "typescript": "^5.8.3",
        "vite": "^6.2.1",
        "vite-plugin-singlefile": "^2.3.0",
        "vitest": "^4.1.4"
    }
}